# CaseFlow — local Docker Compose environment overrides
# Copy to .env and adjust as needed. All values shown are defaults used
# when the variable is not set.

# ── Ports (change if these conflict with local services) ──────────────────────
APP_PORT=8080
POSTGRES_PORT=5432
MONGO_PORT=27017
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=caseflow
POSTGRES_PASSWORD=caseflow_dev

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=caseflow

# ── App behaviour ─────────────────────────────────────────────────────────────
# Set to 'dev' to load seed data on first startup
SPRING_PROFILES_ACTIVE=

# CORS: comma-separated list of allowed FE origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level for com.caseflow (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL_APP=INFO
